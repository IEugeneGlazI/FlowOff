@Flowoff.Web_HostAddress = http://localhost:5277
@customer_email = customer@flowoff.local
@customer_password = Customer123!
@customer_token =
@product_id =

### Register customer
POST {{Flowoff.Web_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "email": "{{customer_email}}",
  "password": "{{customer_password}}",
  "fullName": "Test Customer"
}

### Confirm email
GET {{Flowoff.Web_HostAddress}}/api/auth/confirm-email?userId=USER_ID&token=TOKEN

### Login
POST {{Flowoff.Web_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "{{customer_email}}",
  "password": "{{customer_password}}"
}

### Categories
GET {{Flowoff.Web_HostAddress}}/api/categories

### Colors
GET {{Flowoff.Web_HostAddress}}/api/colors

### Flower types
GET {{Flowoff.Web_HostAddress}}/api/flowerins

### Catalog
GET {{Flowoff.Web_HostAddress}}/api/products

### Product details
GET {{Flowoff.Web_HostAddress}}/api/products/{{product_id}}

### My cart
GET {{Flowoff.Web_HostAddress}}/api/cart
Authorization: Bearer {{customer_token}}

### Add item to cart
POST {{Flowoff.Web_HostAddress}}/api/cart/items
Authorization: Bearer {{customer_token}}
Content-Type: application/json

{
  "productId": "{{product_id}}",
  "quantity": 3
}

### Create order
POST {{Flowoff.Web_HostAddress}}/api/orders
Authorization: Bearer {{customer_token}}
Content-Type: application/json

{
  "deliveryMethod": "Delivery",
  "deliveryAddress": "Москва, ул. Цветочная, д. 15",
  "payOnPickup": false,
  "items": [
    {
      "productId": "{{product_id}}",
      "quantity": 1
    }
  ]
}

### My orders
GET {{Flowoff.Web_HostAddress}}/api/orders/my
Authorization: Bearer {{customer_token}}

### My support requests
GET {{Flowoff.Web_HostAddress}}/api/supportrequests/my
Authorization: Bearer {{customer_token}}

### Create support request
POST {{Flowoff.Web_HostAddress}}/api/supportrequests
Authorization: Bearer {{customer_token}}
Content-Type: application/json

{
  "subject": "Уточнение по заказу",
  "message": "Подскажите, пожалуйста, когда будет обновлен статус заказа."
}

### Florist orders
GET {{Flowoff.Web_HostAddress}}/api/florist/orders
Authorization: Bearer FLORIST_TOKEN

### Complete pickup order
PATCH {{Flowoff.Web_HostAddress}}/api/florist/orders/ORDER_ID/complete-pickup
Authorization: Bearer FLORIST_TOKEN

### Update product
PUT {{Flowoff.Web_HostAddress}}/api/products/PRODUCT_ID
Authorization: Bearer FLORIST_TOKEN
Content-Type: application/json

{
  "name": "Обновленный товар",
  "description": "Новое описание",
  "price": 190,
  "isVisible": true
}

### Delete product
DELETE {{Flowoff.Web_HostAddress}}/api/products/PRODUCT_ID
Authorization: Bearer FLORIST_TOKEN

### Promotions
GET {{Flowoff.Web_HostAddress}}/api/promotions

### Create promotion
POST {{Flowoff.Web_HostAddress}}/api/promotions
Authorization: Bearer ADMIN_TOKEN
Content-Type: application/json

{
  "title": "Весенние скидки",
  "description": "Скидка на выбранные позиции каталога",
  "discountPercent": 10,
  "startsAtUtc": "2026-05-02T09:00:00Z",
  "endsAtUtc": "2026-05-12T21:00:00Z",
  "bouquetIds": [],
  "flowerIds": [],
  "giftIds": []
}

### Admin statistics
GET {{Flowoff.Web_HostAddress}}/api/admin/statistics
Authorization: Bearer ADMIN_TOKEN
